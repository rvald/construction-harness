# Takeoff service configuration (12-factor). Copy to .env for local overrides.
# docker-compose sets these for the containers; this file documents the surface.
TAKEOFF_ENVIRONMENT=local
TAKEOFF_DATABASE_URL=postgresql+psycopg://takeoff:takeoff@postgres:5432/takeoff
TAKEOFF_REDIS_URL=redis://redis:6379/0
TAKEOFF_S3_ENDPOINT_URL=http://minio:9000
TAKEOFF_S3_REGION=us-east-1
TAKEOFF_S3_ACCESS_KEY=minioadmin
TAKEOFF_S3_SECRET_KEY=minioadmin
TAKEOFF_S3_BUCKET=takeoff
TAKEOFF_MAX_UPLOAD_BYTES=524288000
TAKEOFF_JOB_TIMEOUT_SECONDS=1200
TAKEOFF_RQ_QUEUE_NAME=takeoff
